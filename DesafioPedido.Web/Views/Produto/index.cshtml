<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body class="bg-light">

    <div class="container mt-5">
        <div class="card shadow">
            <div class="container mt-5">
                <div class="card-body">
                    <div class="card-body">

                        <!-- Botão Novo produto -->
                        <div class="mb-3">
                            <a asp-action="Create" class="btn btn-success">
                                + Novo produto
                            </a>
                        </div>

                        <!-- Filtros em tempo real -->
                        <div class="row g-2 mb-3">

                            <!-- Busca por Nome -->
                            <div class="col-md-4">
                                <div class="input-group">
                                    <span class="input-group-text bg-white">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="text-muted" viewBox="0 0 16 16">
                                            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zm-5.242 1.656a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z" />
                                        </svg>
                                    </span>
                                    <input type="text" id="filtroNome"
                                           class="form-control border-start-0" placeholder="Buscar por nome..." />
                                </div>
                            </div>

                            <!-- Filtro por Estoque -->
                            <div class="col-md-4">
                                <div class="input-group">
                                    <span class="input-group-text bg-white">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="text-muted" viewBox="0 0 16 16">
                                            <path d="M6 10.5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 0 1h-3a.5.5 0 0 1-.5-.5m-2-3a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5m-2-3a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 0 1h-11a.5.5 0 0 1-.5-.5" />
                                        </svg>
                                    </span>
                                    <select id="filtroEstoque" class="form-select border-start-0">
                                        <option value="">Todos os produtos</option>
                                        <option value="em_estoque">Em estoque</option>
                                        <option value="sem_estoque">Sem estoque</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Contador -->
                            <div class="col-md-2 d-flex align-items-center">
                                <span id="contadorResultados" class="text-muted small"></span>
                            </div>

                            <!-- Limpar -->
                            <div class="col-md-2">
                                <button type="button" id="btnLimparFiltros" class="btn btn-outline-secondary w-100">Limpar</button>
                            </div>
                        </div>

                        <!-- Aviso sem resultados -->
                        <div id="semResultados" class="text-center text-muted py-4 d-none">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16" class="mb-2 d-block mx-auto">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zM2.5 6.5a4 4 0 1 1 8 0 4 4 0 0 1-8 0z" />
                            </svg>
                            Nenhum produto encontrado para os filtros aplicados.
                        </div>

                        <table class="table table-striped table-hover align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>ID</th>
                                    <th>Nome</th>
                                    <th>Descrição</th>
                                    <th>Preço</th>
                                    <th>Quantidade em Estoque</th>
                                    <th class="text-center">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var produto in Model)
                                {
                                    <tr data-nome="@produto.Nome.ToLower()" data-estoque="@produto.QuantidadeEstoque">
                                        <td>@produto.ProdutoId</td>
                                        <td>@produto.Nome</td>
                                        <td>@produto.Descricao</td>
                                        <td>R$ @produto.Preco.ToString("F2")</td>
                                        <td>@produto.QuantidadeEstoque</td>
                                        <td class="text-center">
                                            <a asp-action="Details" asp-route-id="@produto.ProdutoId"
                                                   class="btn btn-sm btn-primary">
                                                Ver Detalhes
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@produto.ProdutoId"
                                                   class="btn btn-sm btn-warning">
                                                Editar
                                            </a>
                                            <button class="btn btn-sm btn-danger"
                                                    onclick="abrirModalExcluir(@produto.ProdutoId, '@produto.Nome')">
                                                Excluir
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <!-- Modal de Confirmação -->
                        <div class="modal fade" id="modalExcluir" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">

                                    <div class="modal-header">
                                        <h5 class="modal-title">Confirmar Exclusão</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>

                                    <div class="modal-body">
                                        Tem certeza que deseja excluir o produto <strong id="nomeProdutoModal"></strong>?
                                    </div>

                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary"
                                                data-bs-dismiss="modal">
                                            Cancelar
                                        </button>

                                        <form id="formExcluir" method="post" asp-controller="produto" asp-action="Delete">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger">
                                                Excluir
                                            </button>
                                        </form>
                                    </div>

                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            // Modal de exclusão
            function abrirModalExcluir(id, nome) {
            document.getElementById('nomeProdutoModal').innerText = nome;
            document.getElementById('formExcluir').action = '/Produto/Delete/' + id;

            var modal = new bootstrap.Modal(document.getElementById('modalExcluir'));
            modal.show();
            }

            // Filtros em tempo real
            const filtroNome    = document.getElementById('filtroNome');
            const filtroEstoque = document.getElementById('filtroEstoque');
            const btnLimpar     = document.getElementById('btnLimparFiltros');
            const contador      = document.getElementById('contadorResultados');
            const semResultados = document.getElementById('semResultados');

            function aplicarFiltros() {
            const nome    = filtroNome.value.toLowerCase().trim();
            const estoque = filtroEstoque.value;

            const linhas = document.querySelectorAll('tbody tr');
            let visiveis = 0;

            linhas.forEach(tr => {
            const nomeProduto = tr.dataset.nome || '';
            const qtd         = parseInt(tr.dataset.estoque) || 0;

            const matchNome    = nome === '' || nomeProduto.includes(nome);
            const matchEstoque = estoque === ''
            || (estoque === 'em_estoque'  && qtd > 0)
            || (estoque === 'sem_estoque' && qtd === 0);

            if (matchNome && matchEstoque) {
            tr.classList.remove('d-none');
            visiveis++;
            } else {
            tr.classList.add('d-none');
            }
            });

            const total = linhas.length;
            contador.textContent = visiveis === total
            ? `${total} produto(s)`
            : `${visiveis} de ${total} produto(s)`;

            semResultados.classList.toggle('d-none', visiveis > 0);
            }

            function limparFiltros() {
            filtroNome.value    = '';
            filtroEstoque.value = '';
            aplicarFiltros();
            }

            filtroNome.addEventListener('input', aplicarFiltros);
            filtroEstoque.addEventListener('change', aplicarFiltros);
            btnLimpar.addEventListener('click', limparFiltros);

            // Inicializa contador
            aplicarFiltros();
        </script>
    }

</body>
</html>
