@model DesafioPedido.Web.Models.CriarPedidoViewModel

<div class="card shadow" style="max-width: 700px;">
    <div class="card-header">
        <h4>Novo Pedido</h4>
    </div>

    <div class="card-body">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p class="mb-0">@error.ErrorMessage</p>
                }
            </div>
        }

        <form method="post" asp-action="Create">
            @Html.AntiForgeryToken()

            <!-- Cliente -->
            <div class="mb-3">
                <label class="form-label">Cliente</label>
                <select asp-for="ClienteId" class="form-select">
                    <option value="0">Selecione um cliente...</option>
                    @foreach (var cliente in Model.Clientes)
                    {
                        <option value="@cliente.ClienteId">@cliente.Nome</option>
                    }
                </select>

            </div>

            <!-- Itens do Pedido -->
            <label class="form-label"><strong>Produtos</strong></label>
            
            <div id="itens">
                <div class="row g-2 mb-2 item-pedido">
                    <div class="col-7">
                        <select name="Pedido.Itens[0].ProdutoId" class="form-select produto-select">
                            <option value="0">Selecione um produto...</option>
                            @foreach (var produto in Model.Produtos)
                            {
                                <option value="@produto.ProdutoId"
                                        data-preco="@produto.Preco.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                        data-estoque="@produto.QuantidadeEstoque">
                                    @produto.Nome — R$ @produto.Preco.ToString("F2") (Estoque: @produto.QuantidadeEstoque)
                                </option>
                            }
                        </select>
                        <!-- INPUT HIDDEN PARA PASSAR O PREÇO -->
                        <input type="hidden" name="Pedido.Itens[0].PrecoUnitario"
                               class="preco-unitario-input" value="0" />
                    </div>
                    <div class="col-3">
                        <input type="number" name="Pedido.Itens[0].Quantidade"
                               class="form-control quantidade-input"
                               placeholder="Qtd" min="1" value="1" />
                    </div>
                    <div class="col-2 d-flex align-items-center">
                        <button type="button" class="btn btn-danger btn-sm" onclick="removerItem(this)">✕</button>
                    </div>
                </div>
            </div>

            <button type="button" class="btn btn-outline-secondary btn-sm mb-3" onclick="adicionarItem()">
                + Adicionar Produto
            </button>

            <!-- Total -->
            <div class="alert alert-light border">
                <strong>Total: R$ <span id="valorTotal">0,00</span></strong>
            </div>

            <button type="submit" class="btn btn-success">Salvar Pedido</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
@section Scripts {
    <script>
         // Lista de produtos para o JS
         const produtos = {
                     @foreach (var p in Model.Produtos)
             {
                                                     @:@p.ProdutoId: { preco: parseFloat(@p.Preco.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)), estoque: @p.QuantidadeEstoque },
         }
                 };

         let indice = 1;

         function adicionarItem() {
             const template = document.querySelector('.item-pedido').cloneNode(true);

             // Limpa os valores do clone e corrige os índices dos names
             template.querySelectorAll('select, input').forEach(el => {
                 el.name = el.name.replace(/Itens\[\d+\]/, `Itens[${indice}]`);

                 if (el.classList.contains('quantidade-input')) {
                     el.value = 1;
                 } else if (el.classList.contains('preco-unitario-input')) {
                     el.value = '0';
                 } else if (el.tagName === 'SELECT') {
                     el.selectedIndex = 0;
                 }
             });

             // Adiciona event listeners ao novo item
             const selectProduto = template.querySelector('.produto-select');
             if (selectProduto) {
                 selectProduto.addEventListener('change', function () {
                     const produtoId = this.value;
                     const precoInput = this.closest('.item-pedido').querySelector('.preco-unitario-input');
                     precoInput.value = (produtoId && produtos[produtoId]) ? produtos[produtoId].preco : '0';
                     recalcularTotal();
                 });
             }

             const inputQtd = template.querySelector('.quantidade-input');
             if (inputQtd) {
                 inputQtd.addEventListener('input', recalcularTotal);
             }

             document.getElementById('itens').appendChild(template);
             indice++;
             recalcularTotal();
         }

        // fim do adicionarItem item

         function removerItem(btn) {
             const itens = document.querySelectorAll('.item-pedido');
             if (itens.length > 1) {
                 btn.closest('.item-pedido').remove();
                 recalcularTotal();
             }
         }

         function recalcularTotal() {
             let total = 0;
             document.querySelectorAll('.item-pedido').forEach(item => {
                 const produtoId = item.querySelector('.produto-select').value;
                 const qtd = parseInt(item.querySelector('.quantidade-input').value) || 0;
                 if (produtoId && produtos[produtoId]) {
                     total += produtos[produtoId].preco * qtd;
                 }
             });
             document.getElementById('valorTotal').innerText = total.toFixed(2).replace('.', ',');
         }

         // Inicializar event listeners quando o DOM estiver pronto
          document.addEventListener('DOMContentLoaded', function() {
             document.querySelectorAll('.produto-select').forEach(select => {
                 select.addEventListener('change', function() {
                     const produtoId = this.value;
                     const precoInput = this.closest('.item-pedido').querySelector('.preco-unitario-input');
            
                     if (produtoId && produtos[produtoId]) {
                         precoInput.value = produtos[produtoId].preco;
                     } else {
                         precoInput.value = '0';
                     }
            
                     recalcularTotal();
                 });
             });
    
             document.querySelectorAll('.quantidade-input').forEach(input => {
                 input.addEventListener('input', recalcularTotal);
             });
    
             recalcularTotal();
         });
    </script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
}