@model DesafioPedido.Web.Models.ListarPedidosViewModel

<div class="card shadow">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Pedidos</h4>
        <a asp-action="Create" class="btn btn-success btn-sm">+ Novo Pedido</a>
    </div>

    <div class="card-body">

        <!-- Filtros -->
        <form method="get" asp-action="Index" class="row g-2 mb-4">

            <div class="col-md-4">
                <select name="clienteId" class="form-select">
                    <option value="">Todos os clientes</option>
                    @foreach (var cliente in Model.Clientes)
                    {
                        <option value="@cliente.ClienteId"
                                selected="@(Model.ClienteIdFiltro == cliente.ClienteId)">
                            @cliente.Nome
                        </option>
                    }
                </select>
            </div>

            @* <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">Todos os status</option>
                    @foreach (var s in new[] { "Novo", "Processando", "Finalizado" })
                    {
                        <option value="@s" selected="@(Model.StatusFiltro == s)">@s</option>
                    }
                </select>
            </div> *@

            @* <div class="col-auto">
                <button type="submit" class="btn btn-primary">Filtrar</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Limpar</a>
            </div> *@

        </form>

      
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Cliente</th>
                    <th>Data</th>
                    <th>Valor Total</th>
                    <th>Status</th>
                    <th class="text-center">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pedido in Model.Pedidos)
                {
                    <tr>
                        <td>@pedido.PedidoId</td>
                        <td>@pedido.NomeCliente</td>
                        <td>@pedido.DataPedido.ToString("dd/MM/yyyy")</td>
                        <td>R$ @pedido.ValorTotal.ToString("F2")</td>
                        <td>
                            @{
                                var badge = pedido.Status switch
                                {
                                    "Novo" => "bg-primary",
                                    "Processando" => "bg-warning text-dark",
                                    "Finalizado" => "bg-success",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badge">@pedido.Status</span>
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@pedido.PedidoId"
                                   class="btn btn-sm btn-primary">
                                Detalhes
                            </a>
                            <a asp-action="Details" asp-route-id="@pedido.PedidoId"
                                   class="btn btn-sm btn-warning">
                                Editar
                            </a>
                            <button class="btn btn-sm btn-danger"
                                    onclick="abrirModalExcluir(@pedido.PedidoId)">
                                Excluir
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <!-- Modal de Confirmação -->
        <div class="modal fade" id="modalExcluir" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">Confirmar Exclusão</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        Tem certeza que deseja excluir o pedido ? <strong id="nomePedidoModal"></strong>?
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Cancelar
                        </button>

                        <form id="formExcluir" method="post" asp-controller="Pedido" asp-action="Delete">
                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-danger">
                                Excluir
                            </button>
                        </form>
                    </div>

                </div>
            </div>
        </div>
 
    </div>
</div>
@section Scripts {
    <script>
        function abrirModalExcluir(id) {
            document.getElementById('formExcluir').action = '/Pedido/Delete/' + id;
            var modal = new bootstrap.Modal(document.getElementById('modalExcluir'));
            modal.show();
        }
    </script>
}